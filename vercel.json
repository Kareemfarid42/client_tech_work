{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/mlo",
      "destination": "/mlo.html"
    },
    {
      "source": "/homeservices",
      "destination": "/homeservices.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}